## 3. Solar Geometry & Extraterrestrial Irradiance

```elixir
lat_input = Kino.Input.number("Latitude (°N)", default: 39.9)  # Ankara
Kino.render(lat_input)

lat = Kino.Input.read(lat_input)

# Annual daily maximum extraterrestrial irradiance
annual_data =
  Enum.map(1..365, fn day ->
    decl  = EnergyX.Renewable.Solar.declination(day)
    omega = EnergyX.Renewable.Solar.hour_angle(12.0)  # solar noon
    g0    = EnergyX.Renewable.Solar.extraterrestrial_irradiance(day, lat, decl, omega)
    alt   = EnergyX.Renewable.Solar.solar_altitude(lat, decl, omega)
    %{"Day of Year" => day, "G₀ (W/m²)" => g0, "Solar Elevation (°)" => Float.round(alt, 2),
      "Declination (°)" => decl}
  end)

Vl.new(width: 650, height: 320, title: "Extraterrestrial Irradiance & Solar Elevation at Solar Noon (Latitude #{lat}°N)")
|> Vl.data_from_values(annual_data)
|> Vl.layers([
  Vl.new() |> Vl.mark(:line, color: "#F5A623", stroke_width: 2)
    |> Vl.encode_field(:x, "Day of Year", type: :quantitative)
    |> Vl.encode_field(:y, "G₀ (W/m²)", type: :quantitative),
  Vl.new() |> Vl.mark(:line, color: "#2E75B6", stroke_width: 2, stroke_dash: [4,2])
    |> Vl.encode_field(:x, "Day of Year", type: :quantitative)
    |> Vl.encode_field(:y, "Solar Elevation (°)", type: :quantitative)
])
|> Kino.VegaLite.new()
```


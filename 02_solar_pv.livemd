# ☀️ EnergyX — Notebook 02
## Solar Energy: PV, CSP, PVT & Passive Systems

```elixir
Mix.install([
  {:energyx, "~> 1.0"},
  {:kino, "~> 0.12"},
  {:kino_vega_lite, "~> 0.1"},
  {:vega_lite, "~> 0.1"}
])
alias VegaLite, as: Vl
```

---

## 1. PV System Output — Interactive Calculator

```elixir
area_input = Kino.Input.number("PV Area (m²)", default: 50)
eta_input  = Kino.Input.number("Module Efficiency (%)", default: 21.0)
pr_input   = Kino.Input.number("Performance Ratio (%)", default: 82.0)
noct_input = Kino.Input.number("NOCT (°C)", default: 45.0)
t_amb_input= Kino.Input.number("Ambient Temperature (°C)", default: 25.0)
Kino.Layout.grid([area_input, eta_input, pr_input, noct_input, t_amb_input], columns: 3)
```

```elixir
area = Kino.Input.read(area_input)
eta  = Kino.Input.read(eta_input) / 100.0
pr   = Kino.Input.read(pr_input)  / 100.0
noct = Kino.Input.read(noct_input)
t_amb= Kino.Input.read(t_amb_input)

irradiance_data =
  Enum.map(0..20, fn i ->
    g = i * 50
    cell_t = EnergyX.Renewable.Solar.pv_cell_temperature(%{t_ambient: t_amb, irradiance: g, noct: noct})
    eta_corr = EnergyX.Renewable.Solar.pv_efficiency_temperature(%{
                 eta_ref: eta, beta_temp: 0.0045, t_cell: cell_t.t_cell_c})
    pv = EnergyX.Renewable.Solar.pv_power(%{irradiance: g, area: area,
                                             efficiency: eta_corr.efficiency, performance_ratio: pr})
    %{
      "Irradiance (W/m²)" => g,
      "Power (kW)"         => pv.power_kw,
      "Cell Temp (°C)"     => cell_t.t_cell_c,
      "Eff. at Temp (%)"   => Float.round(eta_corr.efficiency * 100, 2)
    }
  end)

Vl.new(width: 650, height: 340, title: "PV Output vs Irradiance (temperature-corrected)")
|> Vl.data_from_values(irradiance_data)
|> Vl.mark(:line, point: true, color: "#F5A623", stroke_width: 2.5)
|> Vl.encode_field(:x, "Irradiance (W/m²)", type: :quantitative)
|> Vl.encode_field(:y, "Power (kW)", type: :quantitative)
|> Kino.VegaLite.new()
```

---

## 2. Single-Diode PV Cell Model (5-Parameter)

```elixir
# Standard crystalline silicon cell at 25°C
cell = EnergyX.Renewable.Solar.single_diode_mpp(%{
  i_ph: 8.5,     # A  photocurrent
  i_0:  1.0e-10, # A  dark saturation current
  n:    1.3,     # -  ideality factor
  rs:   0.30,    # Ω  series resistance
  rsh:  200.0,   # Ω  shunt resistance
  t_k:  298.15   # K
})

IO.puts("""
Single-Diode Model Results (c-Si cell, STC):
  V_oc = #{cell.v_oc_v} V
  I_sc = #{cell.i_sc_a} A
  V_mpp = #{cell.v_mpp_v} V
  I_mpp = #{cell.i_mpp_a} A
  P_mpp = #{cell.p_mpp_w} W
  Fill Factor = #{Float.round(cell.fill_factor * 100, 2)}%
""")

# I-V sweep
iv_data =
  Enum.map(0..100, fn i ->
    v = i * cell.v_oc_v / 100.0
    curr = max(cell.i_sc_a - 1.0e-10 * (:math.exp(v / cell.thermal_voltage_v) - 1) - v / 200.0, 0.0)
    %{"Voltage (V)" => Float.round(v, 3), "Current (A)" => Float.round(curr, 4),
      "Power (W)"   => Float.round(v * curr, 4)}
  end)

Vl.new(width: 650, height: 320, title: "PV Cell I-V Curve (Single-Diode Model)")
|> Vl.data_from_values(iv_data)
|> Vl.layers([
  Vl.new() |> Vl.mark(:line, color: "#2E75B6", stroke_width: 2.5)
    |> Vl.encode_field(:x, "Voltage (V)", type: :quantitative)
    |> Vl.encode_field(:y, "Current (A)", type: :quantitative),
  Vl.new() |> Vl.mark(:line, color: "#ED7D31", stroke_width: 2, stroke_dash: [5,3])
    |> Vl.encode_field(:x, "Voltage (V)", type: :quantitative)
    |> Vl.encode_field(:y, "Power (W)", type: :quantitative)
])
|> Kino.VegaLite.new()
```


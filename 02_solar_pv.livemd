## 6. Annual Yield Comparison — Location vs Tilt

```elixir
locations = [
  %{city: "Ankara", lat: 39.9, psh: 5.2},
  %{city: "İstanbul", lat: 41.0, psh: 4.4},
  %{city: "Antalya", lat: 36.9, psh: 5.8},
  %{city: "London", lat: 51.5, psh: 2.8},
  %{city: "Dubai", lat: 25.2, psh: 6.2},
  %{city: "Nairobi", lat: -1.3, psh: 5.9},
]

p_kwp = 10.0
pr    = 0.80

yield_data =
  Enum.map(locations, fn loc ->
    yield = EnergyX.Renewable.Solar.pv_annual_yield(%{p_peak_kwp: p_kwp, h_annual: loc.psh * 365, pr: pr})
    %{"City"                    => loc.city,
      "PSH (h/day)"             => loc.psh,
      "Annual Yield (MWh)"      => Float.round(yield.annual_energy_kwh / 1000, 2),
      "Specific Yield (kWh/kWp)" => yield.specific_yield_kwh_per_kwp,
      "Capacity Factor (%)"     => yield.capacity_factor_pct}
  end)

Kino.DataTable.new(yield_data)
```


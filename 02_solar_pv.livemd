## 4. PVT Combined Heat & Power

```elixir
pvt = EnergyX.Renewable.Solar.pvt_output(%{
  irradiance: 900, area_m2: 20.0, t_ambient: 30.0,
  t_fluid_inlet: 35.0, eta_pv_ref: 0.17, beta_pvt: 0.0045,
  fr: 0.88, tau_alpha: 0.82, ul: 6.5
})

IO.puts("""
PVT Panel Output (G=900 W/m², T_amb=30°C, T_fluid,in=35°C):
  Electrical power:    #{pvt.electrical_power_w} W  (η_el = #{pvt.electrical_efficiency * 100 |> Float.round(2)}%)
  Thermal power:       #{pvt.thermal_power_w} W    (η_th = #{pvt.thermal_efficiency * 100 |> Float.round(2)}%)
  Combined efficiency: #{pvt.total_efficiency * 100 |> Float.round(2)}%
  Cell temperature:    #{pvt.t_cell_c}°C
""")

# PVT vs PV-only across temperature range
pvt_compare =
  Enum.map(15..65//5, fn t_fluid ->
    pvt_res = EnergyX.Renewable.Solar.pvt_output(%{
      irradiance: 900, area_m2: 1.0, t_ambient: 25.0, t_fluid_inlet: t_fluid * 1.0,
      eta_pv_ref: 0.17, beta_pvt: 0.0045, fr: 0.88, tau_alpha: 0.82, ul: 6.5})
    %{"Fluid Inlet Temp (°C)" => t_fluid,
      "Electrical η (%)"       => Float.round(pvt_res.electrical_efficiency * 100, 3),
      "Thermal η (%)"          => Float.round(pvt_res.thermal_efficiency * 100, 3),
      "Total η (%)"            => Float.round(pvt_res.total_efficiency * 100, 3)}
  end)

Vl.new(width: 650, height: 320, title: "PVT Efficiency vs Fluid Inlet Temperature (G=900 W/m², T_amb=25°C)")
|> Vl.data_from_values(pvt_compare)
|> Vl.transform(fold: ["Electrical η (%)", "Thermal η (%)", "Total η (%)"], as: ["Type", "η (%)"])
|> Vl.mark(:line, stroke_width: 2)
|> Vl.encode_field(:x, "Fluid Inlet Temp (°C)", type: :quantitative)
|> Vl.encode_field(:y, "η (%)", type: :quantitative)
|> Vl.encode_field(:color, "Type", type: :nominal)
|> Kino.VegaLite.new()
```


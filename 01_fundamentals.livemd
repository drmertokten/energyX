## 1. Thermodynamic Cycle Efficiencies

```elixir
# ── Input widgets ───────────────────────────────────────────────────────────
t_hot_input  = Kino.Input.number("Hot source temperature (°C)", default: 600)
t_cold_input = Kino.Input.number("Cold sink temperature (°C)",  default: 30)
rp_input     = Kino.Input.number("Brayton pressure ratio",      default: 20)
Kino.Layout.grid([t_hot_input, t_cold_input, rp_input], columns: 3)
```

```elixir
t_hot  = Kino.Input.read(t_hot_input)
t_cold = Kino.Input.read(t_cold_input)
rp     = Kino.Input.read(rp_input)

carnot  = EnergyX.Thermal.Thermodynamics.carnot_efficiency(t_hot + 273.15, t_cold + 273.15)
brayton = EnergyX.Thermal.Thermodynamics.brayton_efficiency(%{pressure_ratio: rp})
rankine = EnergyX.Thermal.Thermodynamics.rankine_efficiency(%{t_boiler_c: t_hot, t_condenser_c: t_cold})
ccgt    = EnergyX.Thermal.Thermodynamics.combined_cycle_efficiency(brayton.eta_brayton, rankine.eta_rankine_approx)

IO.puts("""
╔══════════════════════════════════════════════════════╗
║    THERMODYNAMIC CYCLE COMPARISON
╠══════════════════════════════════════════════════════╣
║  Carnot (maximum possible):    #{Float.round(carnot.eta_pct, 2)}%
║  Brayton gas turbine (rp=#{rp}):   #{Float.round(brayton.eta_pct, 2)}%
║  Rankine steam cycle:          #{Float.round(rankine.eta_pct, 2)}%
║  Combined cycle (CCGT):        #{Float.round(ccgt.eta_pct, 2)}%
╚══════════════════════════════════════════════════════╝
""")
```

```elixir
# Efficiency vs hot temperature (Carnot, Brayton, Rankine)
data =
  Enum.map(200..900//20, fn t ->
    th_k = t + 273.15
    tc_k = t_cold + 273.15
    c = 1 - tc_k / th_k
    b = EnergyX.Thermal.Thermodynamics.brayton_efficiency(%{pressure_ratio: rp}).eta_brayton
    r = EnergyX.Thermal.Thermodynamics.rankine_efficiency(%{t_boiler_c: t, t_condenser_c: t_cold}).eta_rankine_approx
    %{"T_hot (°C)" => t, "Carnot (%)" => Float.round(c * 100, 2),
      "Brayton (%)" => Float.round(b * 100, 2), "Rankine (%)" => Float.round(r * 100, 2)}
  end)

Vl.new(width: 650, height: 360, title: "Thermodynamic Cycle Efficiency vs Hot Source Temperature")
|> Vl.data_from_values(data)
|> Vl.transform(fold: ["Carnot (%)", "Brayton (%)", "Rankine (%)"], as: ["Cycle", "Efficiency (%)"])
|> Vl.mark(:line, stroke_width: 2)
|> Vl.encode_field(:x, "T_hot (°C)", type: :quantitative)
|> Vl.encode_field(:y, "Efficiency (%)", type: :quantitative, scale: [domain: [0, 90]])
|> Vl.encode_field(:color, "Cycle", type: :nominal)
|> Kino.VegaLite.new()
```


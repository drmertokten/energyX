## 7. Exergy Analysis

```elixir
# Flow exergy at elevated temperature and pressure
ex = EnergyX.Thermal.Thermodynamics.flow_exergy(%{
  t_k: 500.0, t0_k: 298.15,
  p: 2_000_000.0, p0: 101_325.0,
  cp: 1006.0, r_gas: 287.0
})

IO.puts("""
Flow Exergy (Air stream at 500 K, 20 bar)
────────────────────────────────────────────
Thermal exergy:   #{Float.round(ex.thermal_exergy_j_kg / 1000, 2)} kJ/kg
Pressure exergy:  #{Float.round(ex.pressure_exergy_j_kg / 1000, 2)} kJ/kg
Total exergy:     #{Float.round(ex.exergy_kj_kg, 2)} kJ/kg
""")

# Exergy destruction vs temperature
ex_data =
  Enum.map(300..1200//50, fn t ->
    e = EnergyX.Thermal.Thermodynamics.flow_exergy(%{
          t_k: t * 1.0, t0_k: 298.15, p: 101_325.0, p0: 101_325.0,
          cp: 1006.0, r_gas: 287.0})
    %{"Temperature (K)" => t, "Thermal Exergy (kJ/kg)" => Float.round(e.thermal_exergy_j_kg / 1000, 2)}
  end)

Vl.new(width: 600, height: 300, title: "Thermal Exergy vs Temperature (P = P₀)")
|> Vl.data_from_values(ex_data)
|> Vl.mark(:area, color: "#1F4E79", opacity: 0.7, line: true)
|> Vl.encode_field(:x, "Temperature (K)", type: :quantitative)
|> Vl.encode_field(:y, "Thermal Exergy (kJ/kg)", type: :quantitative)
|> Kino.VegaLite.new()
```


## 6. Dimensionless Numbers — Summary

```elixir
dn_data = [
  %{"Number" => "Reynolds", "Symbol" => "Re", "Formula" => "ρvL/μ", "Physical Meaning" => "Inertia / Viscous forces", "Critical Value" => "< 2300 laminar"},
  %{"Number" => "Nusselt",  "Symbol" => "Nu", "Formula" => "hL/k",  "Physical Meaning" => "Convective / Conductive HT", "Critical Value" => "Correlation-dependent"},
  %{"Number" => "Prandtl",  "Symbol" => "Pr", "Formula" => "μcp/k", "Physical Meaning" => "Momentum / Thermal diffusivity", "Critical Value" => "Air≈0.71, Water≈7"},
  %{"Number" => "Grashof",  "Symbol" => "Gr", "Formula" => "gβΔTL³/ν²", "Physical Meaning" => "Buoyancy / Viscous forces", "Critical Value" => "—"},
  %{"Number" => "Rayleigh", "Symbol" => "Ra", "Formula" => "Gr·Pr", "Physical Meaning" => "Free convection criterion", "Critical Value" => "> 10⁹ turbulent"},
  %{"Number" => "Biot",     "Symbol" => "Bi", "Formula" => "hLc/k", "Physical Meaning" => "Surface / Internal resistance", "Critical Value" => "< 0.1 lumped"},
  %{"Number" => "Fourier",  "Symbol" => "Fo", "Formula" => "αt/L²", "Physical Meaning" => "Dimensionless time (conduction)", "Critical Value" => "—"},
  %{"Number" => "Mach",     "Symbol" => "Ma", "Formula" => "v/a",   "Physical Meaning" => "Flow speed / Sound speed", "Critical Value" => "< 0.3 incompressible"},
  %{"Number" => "Froude",   "Symbol" => "Fr", "Formula" => "v/√(gL)", "Physical Meaning" => "Inertia / Gravity", "Critical Value" => "< 1 subcritical"},
  %{"Number" => "Weber",    "Symbol" => "We", "Formula" => "ρv²L/σ", "Physical Meaning" => "Inertia / Surface tension", "Critical Value" => "—"},
  %{"Number" => "Eckert",   "Symbol" => "Ec", "Formula" => "v²/(cpΔT)", "Physical Meaning" => "Kinetic / Enthalpy", "Critical Value" => "—"},
  %{"Number" => "Stanton",  "Symbol" => "St", "Formula" => "Nu/(Re·Pr)", "Physical Meaning" => "Heat transfer / Thermal capacity", "Critical Value" => "—"},
  %{"Number" => "Peclet",   "Symbol" => "Pe", "Formula" => "Re·Pr", "Physical Meaning" => "Advection / Diffusion", "Critical Value" => "—"},
  %{"Number" => "Strouhal", "Symbol" => "Sr", "Formula" => "fL/v",  "Physical Meaning" => "Oscillating flow frequency", "Critical Value" => "≈0.2 vortex shedding"},
]

Kino.DataTable.new(dn_data)
```

```elixir
# Calculate all numbers for a specific flow condition
result = EnergyX.Thermal.Dimensionless.all(%{
  rho: 1.2, v: 5.0, l: 0.5, mu: 1.81e-5, cp: 1006.0,
  k: 0.026, beta: 3.3e-3, delta_t: 20.0, alpha: 2.2e-5, sigma_s: 0.072
})

IO.puts("Dimensionless numbers for air flow (v=5m/s, L=0.5m, ΔT=20K):")
Enum.each(result, fn {k, v} -> IO.puts("  #{k}: #{Float.round(v * 1.0, 4)}") end)
```


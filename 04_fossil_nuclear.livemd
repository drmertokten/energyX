## 3. Coal Power Plant — Boiler Efficiency & Emissions

```elixir
t_flue_input = Kino.Input.number("Flue gas temperature (°C)", default: 160)
o2_pct_input = Kino.Input.number("O₂ in flue gas (%)",       default: 4.5)
t_amb_input  = Kino.Input.number("Ambient temperature (°C)",  default: 15)
Kino.Layout.grid([t_flue_input, o2_pct_input, t_amb_input], columns: 3)
```

```elixir
t_flue = Kino.Input.read(t_flue_input)
o2_pct = Kino.Input.read(o2_pct_input)
t_amb  = Kino.Input.read(t_amb_input)

siegert = EnergyX.Fossil.Coal.siegert_flue_loss(%{
  t_flue_c: t_flue, t_ambient_c: t_amb, o2_pct: o2_pct, fuel_type: :bituminous_coal})
boiler  = EnergyX.Fossil.Coal.boiler_efficiency_indirect(%{
  q_dry_flue: siegert.flue_loss_pct, q_moisture: 1.2, q_radiation: 0.8, q_other: 0.3})

benchmarks = EnergyX.Fossil.Coal.plant_efficiency_benchmarks()

IO.puts("""
Boiler Efficiency (Indirect Method):
  Flue gas loss (Siegert): #{siegert.flue_loss_pct}%
  Overall boiler η:        #{boiler.boiler_efficiency_pct}%

Plant Benchmarks:
  Sub-critical:    #{benchmarks.subcritical.typical_efficiency_pct}%
  Super-critical:  #{benchmarks.supercritical.typical_efficiency_pct}%
  Ultra-super:     #{benchmarks.ultra_supercritical.typical_efficiency_pct}%
""")

# Flue loss vs temperature sweep
flue_sweep =
  Enum.map(100..300//5, fn t ->
    s = EnergyX.Fossil.Coal.siegert_flue_loss(%{
          t_flue_c: t * 1.0, t_ambient_c: t_amb * 1.0, o2_pct: o2_pct * 1.0,
          fuel_type: :bituminous_coal})
    %{"Flue Gas T (°C)" => t, "Flue Loss (%)" => s.flue_loss_pct}
  end)

Vl.new(width: 600, height: 280, title: "Siegert Flue Gas Loss vs Temperature")
|> Vl.data_from_values(flue_sweep)
|> Vl.mark(:line, color: "#C00000", stroke_width: 2.5)
|> Vl.encode_field(:x, "Flue Gas T (°C)", type: :quantitative)
|> Vl.encode_field(:y, "Flue Loss (%)", type: :quantitative)
|> Kino.VegaLite.new()
```


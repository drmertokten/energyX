## 6. Hydrogen Production & Storage Comparison

```elixir
electro = EnergyX.Hydrogen.FuelCell.electrolyser_h2_production(%{
  current_a: 1000.0, n_cells: 50, v_cell: 1.80, faradaic_eff: 0.97
})

IO.puts("""
PEM Electrolyser (50-cell stack, I=1000 A, V_cell=1.80 V):
  H₂ production:    #{electro.h2_mass_rate_kg_h} kg/h
  Stack power:       #{electro.stack_power_kw} kW
  Specific energy:   #{electro.specific_energy_kwh_kg} kWh/kg H₂
  LHV efficiency:    #{Float.round(electro.efficiency_lhv * 100, 1)}%
""")

storage = EnergyX.Hydrogen.FuelCell.h2_storage_comparison()
IO.puts("H₂ Storage Technology Comparison:")
Enum.each(storage, fn {tech, data} ->
  IO.puts("  #{tech}: #{data.gravimetric_wh_kg} Wh/kg | #{data.volumetric_wh_l} Wh/L")
end)
```

---

## 7. CO₂ Emissions — Technology Comparison

```elixir
ipcc = EnergyX.Carbon.LCA.lifecycle_co2_factors()

co2_data =
  ipcc
  |> Enum.map(fn {tech, data} ->
    %{"Technology"   => tech |> Atom.to_string() |> String.replace("_", " "),
      "Median (g/kWh)" => data.median,
      "Min"            => data.min,
      "Max"            => data.max}
  end)
  |> Enum.sort_by(& &1["Median (g/kWh)"])

Vl.new(width: 680, height: 500, title: "Lifecycle CO₂ Intensity — IPCC AR6 (g CO₂eq/kWh)")
|> Vl.data_from_values(co2_data)
|> Vl.mark(:bar, opacity: 0.85)
|> Vl.encode_field(:y, "Technology", type: :nominal, sort: "x")
|> Vl.encode_field(:x, "Min", type: :quantitative)
|> Vl.encode_field(:x2, "Max")
|> Kino.VegaLite.new()
```


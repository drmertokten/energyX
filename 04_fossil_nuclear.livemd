## 5. PEM Fuel Cell — Polarisation Curve

```elixir
i_range = Enum.map(1..200, & &1 / 100.0)  # 0.01 to 2.0 A/cm²

polarisation_data =
  Enum.map(i_range, fn i ->
    cell = EnergyX.Hydrogen.FuelCell.pem_cell_voltage(%{
      e_rev: 1.18, current_density: i, i0: 1.0e-3,
      alpha: 0.5, r_ohm: 0.15, i_lim: 1.8, t_k: 353.15
    })
    %{"Current (A/cm²)" => i,
      "Cell Voltage (V)"       => cell.cell_voltage_v,
      "Power (W/cm²)"          => cell.power_density_w_cm2}
  end)

Vl.new(width: 650, height: 360, title: "PEM Fuel Cell Polarisation Curve (80°C)")
|> Vl.data_from_values(polarisation_data)
|> Vl.layers([
  Vl.new() |> Vl.mark(:line, color: "#2E75B6", stroke_width: 2.5)
    |> Vl.encode_field(:x, "Current (A/cm²)", type: :quantitative)
    |> Vl.encode_field(:y, "Cell Voltage (V)", type: :quantitative,
                       scale: [domain: [0.0, 1.3]]),
  Vl.new() |> Vl.mark(:line, color: "#ED7D31", stroke_width: 2, stroke_dash: [5,3])
    |> Vl.encode_field(:x, "Current (A/cm²)", type: :quantitative)
    |> Vl.encode_field(:y, "Power (W/cm²)", type: :quantitative)
])
|> Kino.VegaLite.new()
```


## 2. Net-Zero Pathway Calculator

```elixir
co2_input = Kino.Input.number("Current emissions (t CO₂/yr)", default: 10_000.0)
yr_input  = Kino.Input.number("Net-zero target year",         default: 2050)
res_input = Kino.Input.number("Residual emissions (t CO₂)",  default: 200.0)
Kino.Layout.grid([co2_input, yr_input, res_input], columns: 3)
```

```elixir
e0   = Kino.Input.read(co2_input)
ty   = Kino.Input.read(yr_input)
res  = Kino.Input.read(res_input)

pathway = EnergyX.Carbon.GHGAccounting.netzero_pathway(%{
  current_t_co2_yr: e0, target_year: ty, base_year: 2024, residual_t_co2: res})

IO.puts("""
Net-Zero Pathway to #{ty}:
  Annual reduction required: #{pathway.annual_reduction_pct}%/yr
  Total reduction:           #{pathway.total_reduction_pct}%
""")

path_data = pathway.pathway

Vl.new(width: 650, height: 300, title: "Net-Zero Emissions Pathway to #{ty}")
|> Vl.data_from_values(path_data)
|> Vl.mark(:area, color: "#548235", opacity: 0.65, line: %{color: "#375623", stroke_width: 2})
|> Vl.encode_field(:x, "year", type: :quantitative, title: "Year")
|> Vl.encode_field(:y, "emissions_t", type: :quantitative, title: "Emissions (t CO₂/yr)")
|> Kino.VegaLite.new()
```

---

## 3. Lifecycle CO₂ Intensity — Technology Comparison

```elixir
lca_factors = EnergyX.Carbon.LCA.lifecycle_co2_factors()

lca_data =
  lca_factors
  |> Enum.map(fn {tech, data} ->
    %{"Technology"       => tech |> Atom.to_string() |> String.replace("_", " "),
      "Median (g/kWh)"   => data.median,
      "Min (g/kWh)"      => data.min,
      "Max (g/kWh)"      => data.max}
  end)
  |> Enum.sort_by(& &1["Median (g/kWh)"])

Vl.new(width: 680, height: 480,
       title: "Lifecycle CO₂ Intensity — IPCC AR6 (g CO₂eq/kWh)")
|> Vl.data_from_values(lca_data)
|> Vl.mark(:bar, opacity: 0.85)
|> Vl.encode_field(:y, "Technology", type: :nominal, sort: "x")
|> Vl.encode_field(:x, "Min (g/kWh)", type: :quantitative, title: "Lifecycle CO₂ (g CO₂eq/kWh)")
|> Vl.encode_field(:x2, "Max (g/kWh)")
|> Kino.VegaLite.new()
```


## 7. Complete Industrial Energy Audit — Worked Example

```elixir
IO.puts("""
╔══════════════════════════════════════════════════════════════════╗
║    COMPLETE INDUSTRIAL ENERGY AUDIT — EXAMPLE FACILITY
║    Food Processing Plant — 15,000 t/yr production
╚══════════════════════════════════════════════════════════════════╝
""")

# Energy intensity benchmarking
ei = EnergyX.EnergyAudit.energy_intensity(%{
  energy_kwh_yr: 28_500_000.0,
  production_volume: 15_000.0,
  sector: :food_processing})

IO.puts("""
Energy Performance:
  Actual EI:        #{ei.energy_intensity} kWh/t
  Best practice:    #{ei.benchmark_best} kWh/t
  Typical:          #{ei.benchmark_typical} kWh/t
  Performance band: #{ei.performance_band}
  Ratio to best:    #{ei.ratio_to_best}× (#{Float.round((ei.ratio_to_best - 1) * 100, 0)}% above best practice)
""")

# Identify and rank opportunities
opportunities = [
  %{category: :compressed_air, measure: "Fix 38 air leaks (survey complete)",
    annual_savings_usd: 92_000, capex_usd: 18_000},
  %{category: :lighting, measure: "LED retrofit — factory floor + offices",
    annual_savings_usd: 35_000, capex_usd: 62_000},
  %{category: :motors, measure: "VFDs on 8 cooling pumps (avg 22 kW each)",
    annual_savings_usd: 48_000, capex_usd: 96_000},
  %{category: :steam, measure: "Replace 22 failed-open steam traps",
    annual_savings_usd: 41_000, capex_usd: 8_500},
  %{category: :hvac, measure: "BMS setback + scheduling optimisation",
    annual_savings_usd: 28_000, capex_usd: 35_000},
  %{category: :heat_recovery, measure: "Flash steam recovery — condensate return",
    annual_savings_usd: 22_000, capex_usd: 30_000},
  %{category: :process, measure: "Dryer exhaust heat recovery (HX + preheater)",
    annual_savings_usd: 75_000, capex_usd: 180_000},
  %{category: :process, measure: "Pinch analysis + HEN retrofit (3 streams)",
    annual_savings_usd: 110_000, capex_usd: 380_000},
]

ranked = EnergyX.EnergyAudit.opportunity_ranking(opportunities)

IO.puts("Ranked Energy Saving Opportunities:")
IO.puts(String.pad_trailing("Rank", 6) <>
        String.pad_trailing("Category", 18) <>
        String.pad_trailing("Measure", 45) <>
        String.pad_leading("Saving/yr", 12) <>
        String.pad_leading("CAPEX", 10) <>
        String.pad_leading("Payback", 10))
IO.puts(String.duplicate("─", 102))

Enum.each(ranked, fn r ->
  IO.puts(String.pad_trailing("##{r.priority_rank}", 6) <>
          String.pad_trailing("#{r.category}", 18) <>
          String.pad_trailing(String.slice(r.measure, 0, 43), 45) <>
          String.pad_leading("$#{trunc(r.annual_savings_usd)}", 12) <>
          String.pad_leading("$#{trunc(r.capex_usd)}", 10) <>
          String.pad_leading("#{r.payback_years} yr", 10))
end)

total_savings = Enum.sum(Enum.map(ranked, & &1.annual_savings_usd))
total_capex   = Enum.sum(Enum.map(ranked, & &1.capex_usd))
IO.puts(String.duplicate("─", 102))
IO.puts(String.pad_trailing("TOTAL", 79) <>
        String.pad_leading("$#{trunc(total_savings)}", 12) <>
        String.pad_leading("$#{trunc(total_capex)}", 10))
IO.puts("\nOverall payback: #{Float.round(total_capex / total_savings, 1)} years")
```

```elixir
# CO₂ reduction from all savings
total_kwh_saved = total_savings / 0.12   # assuming 0.12 USD/kWh avg
co2_saved_t     = EnergyX.Units.kwh_to_co2_kg(total_kwh_saved, 0.453) / 1000

scope2_before = EnergyX.Carbon.GHGAccounting.scope2_emissions(%{
  electricity_kwh: 28_500_000.0 * 0.40, grid_factor_kgco2_kwh: 0.453})
co2_scope2_before = scope2_before.co2_t

IO.puts("""

CO₂ Impact:
  Estimated energy saved:  #{Float.round(total_kwh_saved / 1000, 0) |> trunc()} MWh/yr
  CO₂ reduction:           #{Float.round(co2_saved_t, 0) |> trunc()} t CO₂/yr
  Scope 2 before:          #{Float.round(co2_scope2_before, 0) |> trunc()} t CO₂/yr (electricity)
  Scope 2 reduction:       #{Float.round(co2_saved_t / co2_scope2_before * 100, 1)}% of current Scope 2

SCC-weighted benefit (USD 130/t CO₂, IEA NZ2050):
  Social value: USD #{Float.round(co2_saved_t * 130, 0) |> trunc()}/yr
""")
```


## 4. Carbon Capture & Storage (CCS) — Cost Analysis

```elixir
# Post-combustion CCS on a coal plant
ccs = EnergyX.Carbon.CCS.post_combustion_ccs(%{
  plant_mw: 500.0, capture_rate: 0.90,
  regen_gj_t: 3.6, co2_intensity_kg_mwh: 900.0, eta_plant: 0.40})

IO.puts("""
Post-Combustion CCS — 500 MW Coal Plant (90% capture):
  CO₂ captured:         #{ccs.co2_captured_t_h} t/h
  Energy penalty:       #{ccs.energy_penalty_mw} MW (#{ccs.energy_penalty_pct}%)
  Net power output:     #{ccs.net_power_mw} MW
  Net plant efficiency: #{Float.round(ccs.net_plant_efficiency * 100, 2)}%
""")

# DAC performance
dac = EnergyX.Carbon.CCS.dac_performance(%{
  technology: :solid_sorbent, co2_t_yr: 10_000.0,
  elec_price: 0.05, heat_price: 0.02})

IO.puts("""
Direct Air Capture — Solid Sorbent (Climeworks-type), 10,000 t CO₂/yr:
  Thermal energy:        #{dac.thermal_energy_kwh_t} kWh_th/t
  Electrical energy:     #{dac.electric_energy_kwh_t} kWh_e/t
  Energy cost:           USD #{dac.energy_cost_usd_t}/t
  Total cost range:      USD #{dac.total_cost_range_usd_t.min}–#{dac.total_cost_range_usd_t.max}/t
  Annual energy:         #{dac.annual_energy_kwh} kWh/yr
""")
```

---

## 5. Carbon Markets — ETS & Social Cost of Carbon

```elixir
# ETS compliance position
ets = EnergyX.Carbon.CarbonMarkets.ets_compliance(%{
  verified_emissions_t: 120_000.0, free_allocation_t: 95_000.0,
  carbon_price_usd_t: 65.0, surplus_sell_option: true})

IO.puts("""
EU ETS Compliance (65 USD/t CO₂):
  Verified emissions:  #{trunc(ets.position_t + 95_000)} t CO₂
  Free allocation:     95,000 t CO₂
  Position:            #{trunc(ets.position_t)} t (#{ets.status})
  Compliance cost:     USD #{ets.compliance_cost_usd}
  Surplus value:       USD #{ets.surplus_value_usd}
""")

# Social cost of carbon reference
scc = EnergyX.Carbon.CarbonMarkets.scc_reference()
scc_data = Enum.map(scc, fn {name, data} ->
  %{"Source" => name |> Atom.to_string() |> String.replace("_", " "), "USD/t CO₂" => data.usd_t}
end) |> Enum.sort_by(& &1["USD/t CO₂"])

Vl.new(width: 650, height: 280, title: "Social Cost of Carbon Reference Values (USD/t CO₂)")
|> Vl.data_from_values(scc_data)
|> Vl.mark(:bar, color: "#7030A0", opacity: 0.82)
|> Vl.encode_field(:y, "Source", type: :nominal, sort: "-x")
|> Vl.encode_field(:x, "USD/t CO₂", type: :quantitative)
|> Kino.VegaLite.new()
```


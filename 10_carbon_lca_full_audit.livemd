IO.puts("")

IO.puts("Unit Conversions (EnergyX.Units):")
IO.puts("  1 kWh → MJ:      #{EnergyX.Units.kwh_to_mj(1.0)} MJ")
IO.puts("  1 toe → kWh:     #{EnergyX.Units.toe_to_kwh(1.0)} kWh")
IO.puts("  25°C → K:        #{EnergyX.Units.celsius_to_kelvin(25.0)} K")
IO.puts("  10 bar → Pa:     #{EnergyX.Units.bar_to_pa(10.0)} Pa")
IO.puts("  100 hp → kW:     #{Float.round(EnergyX.Units.hp_to_kw(100.0), 2)} kW")

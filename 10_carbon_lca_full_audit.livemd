## 6. EPBT & EROI — Renewable Energy LCA

```elixir
epbt_data = [
  %{technology: "Utility PV (monocrystalline)",
    embodied_gj: 2_800.0, annual_gen_kwh: 1_800_000.0, lifetime: 30},
  %{technology: "Wind turbine (onshore)",
    embodied_gj: 3_500.0, annual_gen_kwh: 9_000_000.0, lifetime: 25},
  %{technology: "Wind turbine (offshore)",
    embodied_gj: 8_000.0, annual_gen_kwh: 18_000_000.0, lifetime: 25},
  %{technology: "Hydro (large dam)",
    embodied_gj: 15_000.0, annual_gen_kwh: 50_000_000.0, lifetime: 50},
  %{technology: "Nuclear (Gen III+)",
    embodied_gj: 50_000.0, annual_gen_kwh: 80_000_000.0, lifetime: 60},
  %{technology: "Rooftop PV (polycrystalline)",
    embodied_gj: 1_200.0, annual_gen_kwh: 600_000.0, lifetime: 25},
]

lca_results = Enum.map(epbt_data, fn t ->
  epbt = EnergyX.Carbon.LCA.energy_payback(%{
    embodied_energy_gj: t.embodied_gj,
    annual_gen_kwh: t.annual_gen_kwh,
    lifetime_yr: t.lifetime})
  %{"Technology"     => t.technology,
    "EPBT (yr)"       => epbt.epbt_years,
    "EROI"            => epbt.eroi,
    "Lifetime (yr)"   => t.lifetime}
end)

IO.puts("Energy Payback Time (EPBT) & EROI:")
Kino.DataTable.new(lca_results)
```


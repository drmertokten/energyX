# 🌍 EnergyX — Notebook 10
## GHG Accounting, LCA, CCS, Carbon Markets & Complete Energy Audit

```elixir
Mix.install([
  {:energyx, "~> 1.0"},
  {:kino, "~> 0.12"},
  {:kino_vega_lite, "~> 0.1"},
  {:vega_lite, "~> 0.1"}
])
alias VegaLite, as: Vl
```

---

## 1. GHG Accounting — Scope 1, 2 & 3

```elixir
# Scope 1 — Direct combustion (on-site boilers, vehicles, processes)
scope1_inputs = %{
  natural_gas_m3: 500_000.0,  # m³/yr
  diesel_l:        80_000.0,  # litres/yr (company vehicles)
  coal_bituminous_kg: 200_000.0
}

scope1 = EnergyX.Carbon.GHGAccounting.scope1_emissions(scope1_inputs)
scope1_total_t = Enum.sum(Enum.map(scope1, & &1.co2_t))

# Scope 2 — Purchased electricity (location-based, Turkey grid)
scope2 = EnergyX.Carbon.GHGAccounting.scope2_emissions(%{
  electricity_kwh: 4_500_000.0, grid_factor_kgco2_kwh: 0.453})

IO.puts("""
GHG Inventory — Scope 1 (Direct Combustion):
""")
Enum.each(scope1, fn e ->
  IO.puts("  #{e.fuel}: #{e.amount} #{e.unit} → #{Float.round(e.co2_t, 2)} t CO₂")
end)
IO.puts("  Scope 1 Total: #{Float.round(scope1_total_t, 1)} t CO₂/yr")

IO.puts("""

Scope 2 (Purchased Electricity — Location-Based, TR grid):
  #{trunc(scope2.electricity_kwh)} kWh × #{scope2.emission_factor} kg CO₂/kWh
  Scope 2 Total: #{scope2.co2_t} t CO₂/yr
""")
```

```elixir
# GWP100 values (IPCC AR6)
gwp = EnergyX.Carbon.GHGAccounting.gwp100()
IO.puts("GWP₁₀₀ Values (IPCC AR6, 2021):")
Enum.each(gwp, fn {gas, gwp_val} ->
  IO.puts("  #{gas}: #{gwp_val} kg CO₂eq/kg")
end)
```


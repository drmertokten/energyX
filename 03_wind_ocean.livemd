## 5. Wave Energy — Power Density

```elixir
wave_data =
  for te <- [6, 8, 10, 12, 14], hs <- Enum.map(1..30, & &1 * 0.2) do
    pw = EnergyX.Renewable.WaveTidalOTEC.wave_power_per_meter(%{h_s: hs, t_e: te * 1.0})
    %{"Hs (m)" => Float.round(hs, 1), "J (kW/m)" => pw.wave_power_kw_per_m, "Te" => "Te=#{te}s"}
  end

Vl.new(width: 650, height: 340, title: "Wave Power Density vs Significant Wave Height")
|> Vl.data_from_values(wave_data)
|> Vl.mark(:line, stroke_width: 2)
|> Vl.encode_field(:x, "Hs (m)", type: :quantitative, title: "Significant wave height Hs (m)")
|> Vl.encode_field(:y, "J (kW/m)", type: :quantitative, title: "Wave power J (kW/m)")
|> Vl.encode_field(:color, "Te", type: :nominal)
|> Kino.VegaLite.new()
```

---

## 6. Tidal Stream Power & OTEC

```elixir
# Tidal turbine array
tidal_data =
  Enum.map(0..50, fn i ->
    v = i / 10.0
    p = EnergyX.Renewable.WaveTidalOTEC.tidal_stream_power(%{
          tidal_speed: v, rotor_diameter: 18.0, cp: 0.42})
    %{"Tidal Speed (m/s)" => v, "Power (kW)" => p.power_kw}
  end)

Vl.new(width: 600, height: 300, title: "Tidal Turbine Power Curve (D=18m, Cp=0.42)")
|> Vl.data_from_values(tidal_data)
|> Vl.mark(:area, color: "#548235", opacity: 0.7, line: true)
|> Vl.encode_field(:x, "Tidal Speed (m/s)", type: :quantitative)
|> Vl.encode_field(:y, "Power (kW)", type: :quantitative)
|> Kino.VegaLite.new()
```

```elixir
# OTEC efficiency across temperature differences
otec_data =
  Enum.map(10..30, fn dt ->
    otec = EnergyX.Renewable.WaveTidalOTEC.otec_efficiency(%{
             t_surface_c: 28.0, t_deep_c: 28.0 - dt, eta_fraction: 0.72})
    %{"ΔT (°C)" => dt, "Gross η (%)" => Float.round(otec.eta_gross * 100, 3),
      "Net η (%)" => Float.round(otec.eta_net * 100, 3)}
  end)

Vl.new(width: 600, height: 280, title: "OTEC Efficiency vs Ocean Temperature Difference")
|> Vl.data_from_values(otec_data)
|> Vl.transform(fold: ["Gross η (%)", "Net η (%)"], as: ["Basis", "Efficiency (%)"])
|> Vl.mark(:line, stroke_width: 2)
|> Vl.encode_field(:x, "ΔT (°C)", type: :quantitative)
|> Vl.encode_field(:y, "Efficiency (%)", type: :quantitative)
|> Vl.encode_field(:color, "Basis", type: :nominal)
|> Kino.VegaLite.new()
```

